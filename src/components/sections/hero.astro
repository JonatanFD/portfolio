---
import { Linkedin } from "../ui/svgs/linkedin";
import { Button } from "../ui/button";
import { GithubDark } from "../ui/svgs/githubDark";
import { GithubLight } from "../ui/svgs/githubLight";
import EmailButton from "../email-button.astro";
---

<header class="pt-10 flex flex-col-reverse md:flex-row items-center gap-8">
    <div class="flex-1 space-y-4 text-center md:text-left">
        <h1 class="font-semibold text-3xl md:text-4xl">Hi, I'm Jonatan</h1>
        <h2
            class="text-base md:text-lg text-muted-foreground text-balance font-medium"
        >
            Software Engineer from Lima, Peru. I love designing and building
            scalable and usefull software for everybody.
        </h2>

        <div class="flex flex-wrap justify-center md:justify-start gap-2 pt-2">
            <a
                href="https://www.linkedin.com/in/jonatanacunacor/"
                target="_blank"
            >
                <Button
                    size="sm"
                    variant="outline"
                    className="gap-2 items-center"
                >
                    <Linkedin />
                    <span>LinkedIn</span>
                </Button>
            </a>
            <a href="https://github.com/JonatanFD" target="_blank">
                <Button
                    size="sm"
                    variant="outline"
                    className="gap-2 items-center"
                >
                    <GithubDark className="hidden dark:block" />
                    <GithubLight className="block dark:hidden" />
                    <span>GitHub</span>
                </Button>
            </a>

            <EmailButton hideEmail={true} />
        </div>
    </div>
    <div class="flex-shrink-0 mb-4 md:mb-0">
        <img
            src="me.jpeg"
            alt="Jonatan Acuña Picture"
            class="size-32 md:size-40 rounded-full"
        />
    </div>
</header>
