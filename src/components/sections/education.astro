---
import EducationItem from "../education-item";
import SectionTemplate from "../section-template.astro";

const education = [
    {
        institution: "Universidad Peruana de Ciencias Aplicadas (UPC)",
        logoUrl: "/education/upc.png",
        degree: "Software Engineer",
        period: ["Mar 2023", "Current"] as [string, string],
        description: "",
    },
];
---

<SectionTemplate title="Education">
    <ul>
        {education.map((edu) => <EducationItem client:load {...edu} />)}
    </ul>
</SectionTemplate>
