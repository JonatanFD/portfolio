---
import SectionTemplate from "../section-template.astro";
import WorkExperienceItem from "../work-experience-item.tsx";

const workExperience = [
    {
        company: "ZyTrust",
        brand: "/companies/zytrust.jpeg",
        role: "Junior Software Engineer",
        period: ["Mar 2026", "Current"] as [string, string],
        description:
            "Enhanced the performance and reliability of a high-traffic, 30+ microservices ecosystem. Modernized the system by applying event-driven architecture patterns and automating deployment workflows through robust CI/CD pipelines.",
    },
];
---

<SectionTemplate title="Work Experience">
    <ul>
        {
            workExperience.map((item) => (
                <WorkExperienceItem client:load {...item} />
            ))
        }
    </ul>
</SectionTemplate>
